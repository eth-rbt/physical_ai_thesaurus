---
import { getCollection, getEntries, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectRefs from '../../components/ProjectRefs.astro';

export async function getStaticPaths() {
  const cards = await getCollection('cards');
  return cards.map((card) => ({ params: { id: card.id }, props: { card } }));
}

const { card } = Astro.props;
const d = card.data;
const projects = await getEntries(d.project_ids);
const { Content } = await render(card);

const modeLabel = {
  'grid': 'Grid',
  'axis-1d': '1D axis',
  'scatter-2d': '2D scatter',
}[d.display.mode];
---

<Base title={d.title}>
  <p class="muted"><a href="/">← Thesaurus</a></p>
  <div class="card-grid">
    <div class="card-prose">
      <span class="chip">{d.category} → {d.subcategory}</span>
      <h1>{d.title}</h1>
      <p class="question">{d.card_question}</p>
      <Content />
    </div>
    <div class="card-refs">
      <div class="panel-head">
        <span class="chip">{modeLabel}</span>
        <span class="count">{projects.length} projects</span>
      </div>
      <ProjectRefs projects={projects} display={d.display} />
    </div>
  </div>
</Base>
