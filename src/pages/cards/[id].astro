---
import { getEntry, getEntries, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectRefs from '../../components/ProjectRefs.astro';
import CardSummary from '../../components/CardSummary.astro';
import Thoughts from '../../components/Thoughts.astro';
import { getRole } from '../../lib/auth';

// SSR (output: 'server') so the password gate protects this page per request —
// look the card up by URL param instead of prerendering via getStaticPaths.
const { id } = Astro.params;
const card = id ? await getEntry('cards', id) : undefined;
if (!card) return new Response('Card not found', { status: 404 });
const d = card.data;
const isAdmin = getRole(Astro.cookies) === 'admin';
const projects = await getEntries(d.project_ids);
const { Content } = await render(card);

const modeLabel = {
  'grid': 'Grid',
  'axis-1d': '1D axis',
  'scatter-2d': '2D scatter',
}[d.display.mode];
---

<Base title={d.title}>
  <p class="muted"><a href="/">← Thesaurus</a></p>
  <div class="card-grid">
    <div class="card-prose">
      <span class="chip">{d.category} → {d.subcategory}</span>
      <h1>{d.title}</h1>
      <p class="question">{d.card_question}</p>
      <Content />
      {d.summary && <CardSummary projects={projects} summary={d.summary} />}
    </div>
    <div class="card-refs">
      <div class="panel-head">
        <span class="chip">{modeLabel}</span>
        <span class="count">{projects.length} projects</span>
      </div>
      <ProjectRefs projects={projects} display={d.display} notes={d.project_notes} />
    </div>
  </div>
  <Thoughts entityType="card" entityId={card.id} isAdmin={isAdmin} />
</Base>
