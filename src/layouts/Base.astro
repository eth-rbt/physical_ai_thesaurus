---
import '../styles/global.css';
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Physical AI Thesaurus</title>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href="/">Physical AI Thesaurus</a>
        <span class="tag">physical AI in daily life</span>
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
  </body>
</html>
