---
import type { CollectionEntry } from 'astro:content';
import ProjectTile from './ProjectTile.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
  /** Optional categorical attribute key to cluster by, e.g. "embodiment.form". */
  groupBy?: string;
  /** Optional card-specific one-liners keyed by project id. */
  notes?: Record<string, string>;
}
const { projects, groupBy, notes } = Astro.props;

// Build ordered groups. A project with multiple values for the grouping
// attribute appears under its first value. Ungrouped projects fall under "Other".
type Group = { label: string; items: CollectionEntry<'projects'>[] };
let groups: Group[];
if (groupBy) {
  const map = new Map<string, CollectionEntry<'projects'>[]>();
  for (const p of projects) {
    const label = p.data.attributes[groupBy]?.[0] ?? 'Other';
    (map.get(label) ?? map.set(label, []).get(label)!).push(p);
  }
  groups = [...map.entries()].map(([label, items]) => ({ label, items }));
} else {
  groups = [{ label: '', items: projects }];
}
---

<div class="proj-grid">
  {groups.map((g) => (
    <>
      {g.label && <div class="group-label">{g.label}</div>}
      {g.items.map((p) => <ProjectTile project={p} note={notes?.[p.id]} />)}
    </>
  ))}
</div>
