---
import type { CollectionEntry } from 'astro:content';
import ProjectTile from './ProjectTile.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
  x: { metric: string; label: string; direction: 'asc' | 'desc' };
  y: { metric: string; label: string; direction: 'asc' | 'desc' };
  notes?: Record<string, string>;
}
const { projects, x, y, notes } = Astro.props;

const has = (p: CollectionEntry<'projects'>) =>
  typeof p.data.metrics[x.metric] === 'number' && typeof p.data.metrics[y.metric] === 'number';
const placed = projects.filter(has);
const missing = projects.filter((p) => !has(p));

function scaler(metric: string, direction: 'asc' | 'desc') {
  const vals = placed.map((p) => p.data.metrics[metric]);
  const min = Math.min(...vals);
  const max = Math.max(...vals);
  const span = max - min || 1;
  return (v: number) => {
    const t = (v - min) / span;
    return (direction === 'desc' ? 1 - t : t) * 100;
  };
}
const sx = scaler(x.metric, x.direction);
const sy = scaler(y.metric, y.direction);

// Many projects share the same ordinal (x, y). Group co-located points and fan each
// cluster out on a small deterministic ring so every dot is visible and its label is
// readable. Labels sit beside the dot — toward the left for right-side points so they
// don't run off the plot.
type Pt = { p: CollectionEntry<'projects'>; left: number; bottom: number; side: 'left' | 'right' };
const clamp = (v: number) => Math.max(3, Math.min(97, v));
const groups = new Map<string, CollectionEntry<'projects'>[]>();
for (const p of placed) {
  const key = `${Math.round(sx(p.data.metrics[x.metric]))}_${Math.round(sy(p.data.metrics[y.metric]))}`;
  (groups.get(key) ?? groups.set(key, []).get(key)!).push(p);
}
const pts: Pt[] = [];
for (const members of groups.values()) {
  const n = members.length;
  const baseLeft = sx(members[0].data.metrics[x.metric]);
  const baseBottom = sy(members[0].data.metrics[y.metric]);
  members.forEach((p, i) => {
    let left = baseLeft;
    let bottom = baseBottom;
    if (n > 1) {
      const r = 4 + n * 0.9; // wider ring for denser clusters
      const a = (i / n) * Math.PI * 2 - Math.PI / 2;
      left += Math.cos(a) * r;
      bottom += Math.sin(a) * r * 0.85;
    }
    left = clamp(left);
    bottom = clamp(bottom);
    pts.push({ p, left, bottom, side: left > 55 ? 'left' : 'right' });
  });
}

// Sort the readable grid below by x then y so it roughly tracks the plot left→right.
const ordered = [...placed].sort(
  (a, b) =>
    sx(a.data.metrics[x.metric]) - sx(b.data.metrics[x.metric]) ||
    sy(a.data.metrics[y.metric]) - sy(b.data.metrics[y.metric]),
);
---

<div class="scatter-wrap">
  <div class="scatter">
    <span class="axlabel-x">{x.label}</span>
    <span class="axlabel-y">{y.label}</span>
    {pts.map(({ p, left, bottom, side }) => (
      <a
        class={`pt lab-${side}`}
        href={`/projects/${p.id}/`}
        title={notes?.[p.id] ?? p.data.name}
        style={`left:${left}%; bottom:${bottom}%`}
      >
        <span class="dot"></span>
        <span class="lab">{p.data.name}</span>
      </a>
    ))}
  </div>

  <div class="proj-grid">
    {ordered.map((p) => (
      <ProjectTile
        project={p}
        sub={`${x.metric}: ${p.data.metrics[x.metric]} · ${y.metric}: ${p.data.metrics[y.metric]}`}
        note={notes?.[p.id]}
      />
    ))}
  </div>

  {missing.length > 0 && (
    <p class="muted not-placed">
      Not plotted (missing <code>{x.metric}</code>/<code>{y.metric}</code>): {missing.map((p) => p.data.name).join(', ')}
    </p>
  )}
</div>
