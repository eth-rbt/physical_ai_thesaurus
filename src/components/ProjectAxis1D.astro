---
import type { CollectionEntry } from 'astro:content';
import ProjectTile from './ProjectTile.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
  axis: { metric: string; label: string; direction: 'asc' | 'desc' };
  notes?: Record<string, string>;
}
const { projects, axis, notes } = Astro.props;

// Only projects that have a value for this metric can be placed on the axis.
const placed = projects.filter((p) => typeof p.data.metrics[axis.metric] === 'number');
const missing = projects.filter((p) => typeof p.data.metrics[axis.metric] !== 'number');

const vals = placed.map((p) => p.data.metrics[axis.metric]);
const min = Math.min(...vals);
const max = Math.max(...vals);
const span = max - min || 1;
// Normalized 0..100 position; desc flips so the highest value sits on the left.
const pos = (v: number) => {
  const t = (v - min) / span;
  return (axis.direction === 'desc' ? 1 - t : t) * 100;
};

const ordered = [...placed].sort((a, b) =>
  axis.direction === 'desc'
    ? b.data.metrics[axis.metric] - a.data.metrics[axis.metric]
    : a.data.metrics[axis.metric] - b.data.metrics[axis.metric],
);

// Many projects share the same ordinal value — stack them in a vertical column at
// that position, each dot carrying its own name label.
const bins = new Map<number, CollectionEntry<'projects'>[]>();
for (const p of placed) {
  const v = p.data.metrics[axis.metric];
  (bins.get(v) ?? bins.set(v, []).get(v)!).push(p);
}
const columns = [...bins.entries()]
  .sort((a, b) => a[0] - b[0])
  .map(([value, items]) => ({
    value,
    left: pos(value),
    // Labels extend toward open space: to the left for right-edge columns, else right.
    side: pos(value) > 55 ? 'left' : 'right',
    items,
  }));
const maxStack = Math.max(1, ...columns.map((c) => c.items.length));

// Split a "low → high" style label into its two ends so we can anchor them at the
// left/right of the axis. Falls back to a single right-hand label if there's no arrow.
const ends = axis.label.split(/\s*(?:→|->|↔|—|–|:)\s*/).filter(Boolean);
const hasTwoEnds = ends.length >= 2;
const lowEnd = hasTwoEnds ? ends[0] : '';
const highEnd = hasTwoEnds ? ends[ends.length - 1] : axis.label;
// desc means the high value sits on the left, so swap which end label goes where.
const leftLabel = axis.direction === 'desc' ? highEnd : lowEnd;
const rightLabel = axis.direction === 'desc' ? lowEnd : highEnd;
---

<div class="axis-1d">
  <div class="axis-ends">
    <span>{leftLabel}</span>
    <span>{rightLabel}</span>
  </div>
  <div class="axis-plot" style={`--rows:${maxStack}`}>
    <div class="axis-line"></div>
    {columns.map((c) => (
      <div class={`axis-col ${c.side}`} style={`left:${c.left}%`}>
        {c.items.map((p) => (
          <a class="axis-row" href={`/projects/${p.id}/`} title={notes?.[p.id] ?? p.data.name}>
            <span class="dot"></span>
            <span class="lab">{p.data.name}</span>
          </a>
        ))}
      </div>
    ))}
  </div>

  <div class="proj-grid">
    {ordered.map((p) => (
      <ProjectTile project={p} sub={`${axis.metric}: ${p.data.metrics[axis.metric]}`} note={notes?.[p.id]} />
    ))}
  </div>

  {missing.length > 0 && (
    <p class="muted not-placed">
      Not placed (no <code>{axis.metric}</code> value): {missing.map((p) => p.data.name).join(', ')}
    </p>
  )}
</div>
