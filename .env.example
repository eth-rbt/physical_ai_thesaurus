# --- Phase 1: password gate ---
SITE_PASSWORD=choose-a-shared-password
ADMIN_PASSWORD=choose-a-separate-admin-key
# Sign session cookies. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# --- Phase 2: Supabase (Thoughts + overrides) ---
# From Supabase dashboard → Project Settings → API
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Bypasses RLS for writes done through our API routes. NEVER expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
